@model StudyNotes.Models.Subject

@{
    ViewData["Title"] = "Dodaj predmet";
}

<div class="container mt-4">
    <h2>Dodaj novi predmet</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Naziv predmeta</label>
            <input asp-for="Name" class="form-control" placeholder="Unesite naziv predmeta" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Sačuvaj</button>
        <a asp-action="Index" class="btn btn-secondary">Nazad</a>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}