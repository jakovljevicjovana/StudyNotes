@model StudyNotes.Models.LoginViewModel

@{
    ViewData["Title"] = "Prijava";
}

<div class="auth-center-wrapper">

    <div class="auth-modern-card">

        <div class="auth-top text-center">

            <div class="auth-logo">
                🎓
            </div>

            <h2 class="mt-3">Prijava</h2>

            <p class="text-muted">
                Prijavi se na svoj nalog
            </p>

        </div>

        <form asp-action="Login" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="mb-3">

                <label asp-for="Email"
                       class="form-label">
                    Email adresa
                </label>

                <input asp-for="Email"
                       class="form-control modern-input"
                       placeholder="Unesite email adresu" />

                <span asp-validation-for="Email"
                      class="text-danger"></span>

            </div>

            <div class="mb-3">

                <label asp-for="Password"
                       class="form-label">
                    Lozinka
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control modern-input"
                       placeholder="Unesite lozinku" />

                <span asp-validation-for="Password"
                      class="text-danger"></span>

            </div>

            <div class="form-check mb-4">

                <input asp-for="RememberMe"
                       class="form-check-input" />

                <label asp-for="RememberMe"
                       class="form-check-label">

                    Zapamti me

                </label>

            </div>

            <button type="submit"
                    class="btn modern-auth-btn w-100">

                Prijavi se

            </button>

            <div class="text-center mt-4">

                Nemaš nalog?

                <a asp-controller="Account"
                   asp-action="Register">

                    Registruj se

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}