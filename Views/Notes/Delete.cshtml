@model StudyNotes.Models.Note

@{
    ViewData["Title"] = "Obriši belešku";
}

<div class="container mt-4">
    <div class="container-box">
        <h2 class="page-title">Obriši belešku</h2>

        <div class="alert alert-danger">
            Da li ste sigurni da želite da obrišete belešku:
            <strong>@Model.Title</strong>?
        </div>

        <div class="mb-3">
            <p><strong>Predmet:</strong> @(Model.Subject != null ? Model.Subject.Name : "Bez predmeta")</p>
            <p><strong>Sadržaj:</strong> @Model.Content</p>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">Da, obriši</button>
            <a asp-action="Index" class="btn btn-secondary">Odustani</a>
        </form>
    </div>
</div>