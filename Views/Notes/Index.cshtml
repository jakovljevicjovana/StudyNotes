@model IEnumerable<StudyNotes.Models.Note>

@{
    ViewData["Title"] = "Beleške";
}

<div class="container mt-4">

    <div class="container-box">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">

            <h2 class="page-title mb-0">
                📝 Moje beleške
            </h2>

            <a asp-action="Create"
               class="btn btn-primary">

                + Dodaj belešku

            </a>

        </div>

        <form asp-action="Index"
              method="get"
              class="mb-4">

            <div class="input-group">

                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Pretraži beleške..." />

                <button class="btn btn-primary"
                        type="submit">

                    Pretraži

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Resetuj

                </a>

            </div>

        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info">

                Trenutno nema dodatih beleški.

            </div>
        }
        else
        {
            <div class="row g-4">

                @foreach (var note in Model)
                {
                    <div class="col-md-6 col-lg-4">

                        <div class="note-card">

                            <div class="d-flex justify-content-between align-items-start mb-2">

                                <h5 class="note-title">
                                    @note.Title
                                </h5>

                                @if (note.IsImportant)
                                {
                                    <span class="badge bg-warning text-dark">
                                        ⭐ Važno
                                    </span>
                                }

                            </div>

                            <p class="note-subject">

                                📚
                                @(note.Subject != null
                                    ? note.Subject.Name
                                    : "Bez predmeta")

                            </p>

                            <p class="note-content">
                                @note.Content
                            </p>

                            @if (!string.IsNullOrEmpty(note.FilePath))
                            {
                                <p>

                                    📎

                                    <a href="@note.FilePath"
                                       target="_blank">

                                        @note.FileName

                                    </a>

                                </p>
                            }

                            <small class="text-muted">

                                Kreirano:
                                @note.CreatedAt.ToString("dd.MM.yyyy HH:mm")

                            </small>

                            <div class="mt-3 d-flex gap-2 flex-wrap">

                                <a asp-action="Edit"
                                   asp-route-id="@note.Id"
                                   class="btn btn-warning btn-sm">

                                    Izmeni

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@note.Id"
                                   class="btn btn-danger btn-sm">

                                    Obriši

                                </a>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>